[{\n  \"event_id\": \"void_altar\",\n  \"event_name\": \"The Void Altar\",\n  \"description\": \"A shimmering altar hums with dark energy. Ancient runes pulse in rhythms that match your heartbeat. Something stirs beneath its surface, hungry and patient.\",\n  \"choices\": [\n    {\n      \"text\": \"Offer blood (lose 8 HP, gain 120 gold)\",\n      \"condition\": null,\n      \"effect\": {\n        \"hp_delta\": -8,\n        \"gold_delta\": 120\n      }\n    },\n    {\n      \"text\": \"Offer a card (remove a card from your deck)\",\n      \"condition\": null,\n      \"effect\": {\n        \"remove_card\": true\n      }\n    },\n    {\n      \"text\": \"Offer gold (spend 50 gold, gain a random relic)\",\n      \"condition\": {\n        \"min_gold\": 50\n      },\n      \"effect\": {\n        \"gold_delta\": -50,\n        \"gain_random_relic\": true\n      }\n    },\n    {\n      \"text\": \"Leave\",\n      \"condition\": null,\n      \"effect\": {}\n    }\n  ]\n},{\n  \"event_id\": \"lost_scholar\",\n  \"event_name\": \"The Lost Scholar\",\n  \"description\": \"A trembling figure clutches tomes of forbidden knowledge. Their eyes are wrong — too many irises, no pupils. 'Please,' they whisper, 'I know things. Take what you need. Just don't look at me too long.'\",\n  \"choices\": [\n    {\n      \"text\": \"Accept their knowledge (gain a random card, become Cursed)\",\n      \"condition\": null,\n      \"effect\": {\n        \"gain_random_card\": true,\n        \"gain_curse\": \"madness\"\n      }\n    },\n    {\n      \"text\": \"Take their relic (gain a random relic, lose 10 HP)\",\n      \"condition\": null,\n      \"effect\": {\n        \"gain_random_relic\": true,\n        \"hp_delta\": -10\n      }\n    },\n    {\n      \"text\": \"Offer gold for insight (spend 75 gold, gain 2 random cards)\",\n      \"condition\": {\n        \"min_gold\": 75\n      },\n      \"effect\": {\n        \"gold_delta\": -75,\n        \"gain_random_cards\": 2\n      }\n    },\n    {\n      \"text\": \"Back away slowly\",\n      \"condition\": null,\n      \"effect\": {}\n    }\n  ]\n},{\n  \"event_id\": \"rift_anomaly\",\n  \"event_name\": \"The Rift Anomaly\",\n  \"description\": \"A tear in reality yawns before you, edges crackling with raw void energy. Through it you glimpse a dozen other versions of this moment — in most of them, you don't survive the choice.\",\n  \"choices\": [\n    {\n      \"text\": \"Step through (50%: gain 250 gold OR lose half HP)\",\n      \"condition\": null,\n      \"effect\": {\n        \"random_outcome\": [\n          {\n            \"weight\": 50,\n            \"gold_delta\": 250\n          },\n          {\n            \"weight\": 50,\n            \"hp_percent_delta\": -50\n          }\n        ]\n      }\n    },\n    {\n      \"text\": \"Siphon the energy (gain 1 max HP, upgrade a random card)\",\n      \"condition\": null,\n      \"effect\": {\n        \"max_hp_delta\": 1,\n        \"upgrade_random_card\": true\n      }\n    },\n    {\n      \"text\": \"Seal the rift (gain 45 gold, all enemies in next combat start Vulnerable)\",\n      \"condition\": null,\n      \"effect\": {\n        \"gold_delta\": 45,\n        \"next_combat_flag\": \"all_vulnerable_1\"\n      }\n    },\n    {\n      \"text\": \"Ignore it\",\n      \"condition\": null,\n      \"effect\": {}\n    }\n  ]\n}]